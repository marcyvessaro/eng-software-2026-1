#include<stdio.h>

int main(){
	
	int x=1;
	int somapar=0, somaimpar=0;
	int cp=0,ci=0; 
	
	while(x<=10){
		
		
		if (x%2==0){
			
			somapar=somapar+x; // soma par
				cp++; // conta soma par
			
		}
		else{
			somaimpar=somaimpar+x; //soma impar
			ci++;
	
	}
	x++;	
}
printf("soma de pares: %i, media: %i \n", somapar,somapar/cp); //printa a soma de pares, e a media (soma dos pares dividido pela quantidade de pares)
printf("soma de impares: %i, media: %i \n", somaimpar,somaimpar/ci); // mesma coisa so que com impar

}
