#include<stdio.h>

int main(){
	
	int vi,vf; 
	int sp=0, si=0;
	int cp=0,ci=0; 
	
	printf("entre com o valor inicial \n");
	scanf("%i",&vi);
	printf("entre com o valor final \n");
	scanf("%i",&vf);
	
	if(vi<=vf){
	
	while(vi<=vf){
		
		
		if (vi%2==0){
			
			sp=sp+vi; 
				cp++; 	
		}
		else{
			si=si+vi;
			ci++;
	}
	vi++;
}
}
  	else{
	  	
		while(vi>=vf){
		
		
		if (vi%2==0){
			
			sp=sp+vi; 
				cp++; 	
		}
		else{
			si=si+vi;
			ci++;
	}
	vi--;
}
}

printf("soma de pares: %i, media: %i \n", sp,sp/cp);
printf("soma de impares: %i, media: %i \n", si,si/ci);
}
